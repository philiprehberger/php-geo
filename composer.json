{
    "name": "philiprehberger/php-geo",
    "description": "Geospatial utilities for distance, bounding box, and point-in-polygon calculations",
    "keywords": ["geospatial", "geo", "distance", "haversine", "vincenty", "bounding-box", "point-in-polygon", "coordinates"],
    "homepage": "https://github.com/philiprehberger/php-geo",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Philip Rehberger",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "phpstan/phpstan": "^1.12|^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "PhilipRehberger\\Geo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhilipRehberger\\Geo\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "lint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
